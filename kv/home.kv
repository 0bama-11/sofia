#:import utils kivy.utils
#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp

<HomeScreen>:
    name: "home"

    canvas.before:
        Color:
            rgba: utils.get_color_from_hex("#6A0DAD")
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        spacing: 0

        # HEADER
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(64)
            padding: [dp(18), dp(10), dp(18), dp(4)]

            Label:
                text: "NutriAI"
                font_size: sp(24)
                bold: True
                color: 1, 1, 1, 1
                halign: "left"
                text_size: self.size

            Widget:

            Button:
                size_hint: None, None
                size: dp(44), dp(44)
                background_normal: ""
                background_color: 0, 0, 0, 0
                on_release: root.go_profile()
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex("#4A0080")
                    Ellipse:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: 1, 1, 1, 0.9
                    Ellipse:
                        pos: self.x + dp(10), self.y + dp(22)
                        size: dp(24), dp(14)
                    Ellipse:
                        pos: self.x + dp(16), self.y + dp(14)
                        size: dp(12), dp(12)

        # TARJETAS CALORIAS
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(88)
            padding: [dp(14), 0, dp(14), 0]
            spacing: dp(10)

            BoxLayout:
                orientation: "vertical"
                padding: dp(12)
                spacing: dp(2)
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex("#4A0080CC")
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(14)]
                Label:
                    text: str(int(root.total_calories))
                    font_size: sp(26)
                    bold: True
                    color: 1, 1, 1, 1
                    halign: "center"
                    text_size: self.size
                Label:
                    text: "kcal consumidas"
                    font_size: sp(11)
                    color: 0.85, 0.75, 1, 1
                    halign: "center"
                    text_size: self.size

            BoxLayout:
                orientation: "vertical"
                padding: dp(12)
                spacing: dp(2)
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex("#3D0070CC")
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(14)]
                Label:
                    text: str(int(root.burned_calories))
                    font_size: sp(26)
                    bold: True
                    color: 1, 0.85, 0.3, 1
                    halign: "center"
                    text_size: self.size
                Label:
                    text: "kcal quemadas"
                    font_size: sp(11)
                    color: 0.85, 0.75, 1, 1
                    halign: "center"
                    text_size: self.size

        Widget:
            size_hint_y: None
            height: dp(16)

        # BOTON ESCANEAR con cuchillo y tenedor en canvas
        AnchorLayout:
            size_hint_y: None
            height: dp(200)
            anchor_x: "center"
            anchor_y: "center"

            Button:
                size_hint: None, None
                size: dp(180), dp(180)
                background_normal: ""
                background_color: 0, 0, 0, 0
                on_release: root.go_capture()
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 1
                    Line:
                        points: [self.x + dp(10), self.y + self.height - dp(10), self.x + dp(10), self.y + self.height - dp(45)]
                        width: dp(4)
                    Line:
                        points: [self.x + dp(10), self.y + self.height - dp(10), self.x + dp(45), self.y + self.height - dp(10)]
                        width: dp(4)
                    Line:
                        points: [self.x + self.width - dp(10), self.y + self.height - dp(10), self.x + self.width - dp(10), self.y + self.height - dp(45)]
                        width: dp(4)
                    Line:
                        points: [self.x + self.width - dp(10), self.y + self.height - dp(10), self.x + self.width - dp(45), self.y + self.height - dp(10)]
                        width: dp(4)
                    Line:
                        points: [self.x + dp(10), self.y + dp(10), self.x + dp(10), self.y + dp(45)]
                        width: dp(4)
                    Line:
                        points: [self.x + dp(10), self.y + dp(10), self.x + dp(45), self.y + dp(10)]
                        width: dp(4)
                    Line:
                        points: [self.x + self.width - dp(10), self.y + dp(10), self.x + self.width - dp(10), self.y + dp(45)]
                        width: dp(4)
                    Line:
                        points: [self.x + self.width - dp(10), self.y + dp(10), self.x + self.width - dp(45), self.y + dp(10)]
                        width: dp(4)

                Image:
                    source: "assets/cuchillo_tenedor.png"
                    size_hint: None, None
                    size: dp(140), dp(140)
                    pos: self.parent.x + dp(20), self.parent.y + dp(20)
                    allow_stretch: True

        Label:
            text: "Escanea tus alimentos"
            font_size: sp(18)
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(32)
            halign: "center"
            text_size: self.size

        # SELECCION DE EJERCICIO con figuras en canvas
        Widget:
            size_hint_y: None
            height: dp(12)

        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(90)
            padding: [dp(10), 0, dp(10), 0]
            spacing: dp(8)

            # Caminar
            Button:
                background_normal: ""
                on_release: root.select_exercise("caminar")
                background_color: (0.3, 0, 0.5, 0.9) if root.selected_exercise == "caminar" else (0.2, 0, 0.3, 0.5)
                Image:
                    source: "assets/caminar.webp"
                    size_hint: None, None
                    size: dp(60), dp(60)
                    pos: self.parent.center_x - dp(30), self.parent.y + dp(15)
                    allow_stretch: True

            # Correr
            Button:
                background_normal: ""
                on_release: root.select_exercise("correr")
                background_color: (0.3, 0, 0.5, 0.9) if root.selected_exercise == "correr" else (0.2, 0, 0.3, 0.5)
                Image:
                    source: "assets/correr.png"
                    size_hint: None, None
                    size: dp(60), dp(60)
                    pos: self.parent.center_x - dp(30), self.parent.y + dp(15)
                    allow_stretch: True

            # Saltar
            Button:
                background_normal: ""
                on_release: root.select_exercise("saltar")
                background_color: (0.3, 0, 0.5, 0.9) if root.selected_exercise == "saltar" else (0.2, 0, 0.3, 0.5)
                Image:
                    source: "assets/saltar.png"
                    size_hint: None, None
                    size: dp(60), dp(60)
                    pos: self.parent.center_x - dp(30), self.parent.y + dp(15)
                    allow_stretch: True

        # BARRA DE DISTANCIA
        Widget:
            size_hint_y: None
            height: dp(8)

        BoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: dp(56)
            padding: [dp(18), 0, dp(18), 0]

            Widget:
                size_hint_y: None
                height: dp(8)
                canvas:
                    Color:
                        rgba: 1, 1, 1, 0.3
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(3)]
                    Color:
                        rgba: 1, 1, 1, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: min(root.distance_today / 5.0, 1.0) * self.width, self.height
                        radius: [dp(3)]

            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: dp(36)
                Label:
                    text: str(round(root.distance_today, 2)) + " km"
                    font_size: sp(13)
                    color: 1, 1, 1, 1
                    halign: "left"
                    text_size: self.size
                Label:
                    text: "meta: 5.0 km"
                    font_size: sp(13)
                    color: 1, 1, 1, 0.7
                    halign: "right"
                    text_size: self.size

        # BOTON EMPEZAR
        Widget:
            size_hint_y: None
            height: dp(8)

        AnchorLayout:
            size_hint_y: None
            height: dp(80)
            anchor_x: "center"
            anchor_y: "center"

            Button:
                size_hint: None, None
                size: dp(68), dp(68)
                background_normal: ""
                background_color: 0, 0, 0, 0
                on_release: root.go_exercise()
                canvas.before:
                    Color:
                        rgba: utils.get_color_from_hex("#4A0080")
                    Ellipse:
                        pos: self.pos
                        size: self.size
                    Color:
                        rgba: 1, 1, 1, 1
                    Triangle:
                        points: [self.x + dp(26), self.y + dp(16), self.x + dp(26), self.y + dp(52), self.x + dp(54), self.y + dp(34)]

        Label:
            text: "Empezar"
            font_size: sp(16)
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(26)
            halign: "center"
            text_size: self.size

        # BARRA NAVEGACION INFERIOR
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(68)
            padding: [0, dp(4), 0, 0]
            canvas.before:
                Color:
                    rgba: utils.get_color_from_hex("#1A001A")
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "Podio"
                font_size: sp(11)
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.7, 0.7, 0.7, 1

            Button:
                text: "Amigos"
                font_size: sp(11)
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.7, 0.7, 0.7, 1

            Button:
                text: "Inicio"
                font_size: sp(11)
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1

            Button:
                text: "Social"
                font_size: sp(11)
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.7, 0.7, 0.7, 1

            Button:
                text: "Tienda"
                font_size: sp(11)
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.7, 0.7, 0.7, 1
